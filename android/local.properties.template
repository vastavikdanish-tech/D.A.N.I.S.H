# This file must point to your Android SDK location.
# Android Studio usually creates this automatically.
# Copy this file to local.properties and fill in your SDK path.

# Windows example:
# sdk.dir=C:\\Users\\YourUser\\AppData\\Local\\Android\\Sdk

# macOS example:
# sdk.dir=/Users/YourUser/Library/Android/sdk

# Linux example:
# sdk.dir=/home/YourUser/Android/Sdk
